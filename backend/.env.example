# Server
PORT=4000
NODE_ENV=production
CORS_ORIGIN=*

# SQLite database file path (defaults to backend/database/gsrtc.db)
DB_PATH=

# GSRTC live tracking API
GSRTC_LOGIN_URL=https://live.gsrtc.org/api/auth/login
GSRTC_API_URL=https://live.gsrtc.org/api/vehicle/tooltip
GSRTC_USERNAME=Amnex_Admin
GSRTC_PASSWORD=Amnex@123

# Tracking engine defaults (overridable at runtime from the Settings page)
TRACK_INTERVAL_SECONDS=4
WORKER_COUNT=8
API_MAX_RETRIES=3
API_RETRY_DELAY=1500
API_TIMEOUT=10000
OFFLINE_AFTER_SECONDS=120
IDLE_SPEED_THRESHOLD=5
STOPPED_AFTER_SECONDS=300

# Admin page credentials (HTTP Basic Auth on /api/admin/*)
ADMIN_USER=admin
ADMIN_PASS=admin

LOG_LEVEL=info
